# =============================================================================
# AI Agent Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# =============================================================================
# REQUIRED - API Keys
# =============================================================================

# OpenAI API Key (Required)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server Host (Default: 0.0.0.0 for all interfaces)
HOST=0.0.0.0

# Server Port (Default: 8000)
# Note: Cloud platforms (Render, Railway) provide PORT automatically
PORT=8000

# Environment (development, staging, production)
ENVIRONMENT=development

# Number of Uvicorn workers (production only, default: 4)
WORKERS=4

# Log Level (debug, info, warning, error, critical)
LOG_LEVEL=info

# =============================================================================
# DATABASE (Optional - if using PostgreSQL)
# =============================================================================

# PostgreSQL Connection String
# Format: postgresql://user:password@host:port/database
# DATABASE_URL=postgresql://user:pass@localhost:5432/ai_agent_db

# =============================================================================
# VECTOR DATABASE (ChromaDB)
# =============================================================================

# ChromaDB Persist Directory (Default: ./chroma_db)
# CHROMA_PERSIST_DIR=./chroma_db

# ChromaDB Collection Name (Default: documents)
# CHROMA_COLLECTION=documents

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================

# Upload Directory (Default: ./uploads)
UPLOAD_DIR=./uploads

# Maximum File Size in MB (Default: 10)
MAX_FILE_SIZE_MB=10

# Allowed File Extensions (comma-separated)
ALLOWED_EXTENSIONS=.pdf,.docx

# =============================================================================
# AI MODEL CONFIGURATION
# =============================================================================

# OpenAI Model for Chat (Default: gpt-3.5-turbo)
OPENAI_MODEL=gpt-3.5-turbo

# OpenAI Model for Embeddings (Default: text-embedding-ada-002)
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# Temperature for LLM responses (0.0 - 2.0, Default: 0.7)
LLM_TEMPERATURE=0.7

# Maximum tokens for LLM responses (Default: 2000)
MAX_TOKENS=2000

# =============================================================================
# TRACE LOGGING (Workflow Execution)
# =============================================================================

# SQLite Database for Traces (Default: ./traces.db)
TRACE_DB_PATH=./traces.db

# Enable trace logging (true/false, Default: true)
ENABLE_TRACE_LOGGING=true

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================

# Session timeout in minutes (Default: 60)
SESSION_TIMEOUT_MINUTES=60

# =============================================================================
# CORS CONFIGURATION (Optional)
# =============================================================================

# Allowed origins (comma-separated, * for all)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=*

# Allowed methods (comma-separated)
# CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Allowed headers (comma-separated)
# CORS_HEADERS=*

# =============================================================================
# RATE LIMITING (Optional)
# =============================================================================

# Enable rate limiting (true/false)
# ENABLE_RATE_LIMIT=false

# Requests per minute per IP
# RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# MONITORING & OBSERVABILITY (Optional)
# =============================================================================

# Sentry DSN for error tracking
# SENTRY_DSN=https://xxx@sentry.io/xxx

# Application name for logging
APP_NAME=ai-agent-backend

# =============================================================================
# CLOUD PLATFORM SPECIFIC (Auto-provided by platforms)
# =============================================================================

# AWS Region (for AWS deployments)
# AWS_REGION=us-east-1

# AWS Access Keys (if not using IAM roles)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# Railway/Render automatically provide:
# - PORT (overrides PORT above)
# - DATABASE_URL (if database is linked)
# - REDIS_URL (if Redis is linked)

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Enable debug mode (development only)
DEBUG=false

# Enable auto-reload (development only)
RELOAD=true

# API documentation accessible (true/false)
ENABLE_DOCS=true
